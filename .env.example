DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-a-long-random-secret"

# Login com Google (opcional) — sem essas variáveis, o botão "Continuar com
# Google" fica oculto e a rota /api/auth/google responde 501. Gere um OAuth
# Client ID em https://console.cloud.google.com/apis/credentials (tipo "Web
# application", com seu domínio em "Authorized JavaScript origins").
# GOOGLE_CLIENT_ID e NEXT_PUBLIC_GOOGLE_CLIENT_ID devem ser o MESMO valor —
# o primeiro é lido no servidor (verificação do token), o segundo no
# navegador (carrega o botão do Google); o prefixo NEXT_PUBLIC_ é o que o
# Next.js exige para expor uma env var ao client-side.
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
