DATABASE_URL="file:./dev.db"
JWT_SECRET="replace-with-a-long-random-secret"

# Login com Google (opcional) — sem essas variáveis, o botão "Continuar com
# Google" fica oculto e a rota /api/auth/google responde 501. Gere um OAuth
# Client ID em https://console.cloud.google.com/apis/credentials (tipo "Web
# application", com seu domínio em "Authorized JavaScript origins").
# GOOGLE_CLIENT_ID e NEXT_PUBLIC_GOOGLE_CLIENT_ID devem ser o MESMO valor —
# o primeiro é lido no servidor (verificação do token), o segundo no
# navegador (carrega o botão do Google); o prefixo NEXT_PUBLIC_ é o que o
# Next.js exige para expor uma env var ao client-side.
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""

# E-mail transacional (redefinição de senha) — provedor: Resend.
# Sem RESEND_API_KEY, o fluxo "esqueci a senha" continua funcionando, mas em
# vez de enviar o e-mail o link de redefinição é impresso no console do
# servidor (útil para testar em dev). Crie a chave em https://resend.com
# (grátis: 3.000 e-mails/mês) — começa com "re_".
RESEND_API_KEY=""
# Remetente. Para enviar de verdade a qualquer destinatário, verifique um
# domínio no painel da Resend e use um endereço dele, ex:
#   EMAIL_FROM="CORTIX <nao-responda@seudominio.com>"
# Sem domínio verificado, a Resend só entrega para o SEU próprio e-mail via
# "onboarding@resend.dev" (modo de teste) — que é o padrão quando esta var
# fica vazia.
EMAIL_FROM=""
# Base usada para montar os links dos e-mails. Se vazio, usamos a origem da
# própria requisição (ótimo em dev). Em produção, defina a URL pública, ex:
#   APP_URL="https://app.seudominio.com"
APP_URL=""

# Pagamento (Mercado Pago) — cobrança recorrente das barbearias (assinatura do
# sistema). Sem MERCADOPAGO_ACCESS_TOKEN, o botão "Assinar" ativa o plano na
# hora em modo simulado (útil pra testar a tela) e NENHUMA cobrança acontece.
# Pegue o token em https://www.mercadopago.com.br/developers → Suas integrações
# → Credenciais. Use "TEST-..." para sandbox e "APP_USR-..." em produção.
MERCADOPAGO_ACCESS_TOKEN=""
# IMPORTANTE: o webhook de confirmação precisa de uma URL pública (APP_URL).
# Em produção, cadastre no painel do Mercado Pago a URL de notificação:
#   <APP_URL>/api/billing/webhook
# (o app também envia essa URL em cada assinatura automaticamente).

# WhatsApp (API oficial Meta Cloud) — confirmação de agendamento pro cliente.
# Sem token, as mensagens só aparecem no console do servidor (dev). Crie um app
# no https://developers.facebook.com → produto WhatsApp, pegue o token
# permanente (System User) e o "Phone number ID".
# ATENÇÃO: mensagens iniciadas pela empresa (confirmação/lembrete) exigem um
# TEMPLATE aprovado no painel da Meta. Texto livre só chega a quem te mandou
# mensagem nas últimas 24h.
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
# WHATSAPP_API_VERSION="v21.0"  # opcional
# Webhook de ENTRADA (bot 24/7 no WhatsApp):
WHATSAPP_VERIFY_TOKEN=""   # string qualquer; digite a mesma no painel da Meta
WHATSAPP_BARBERSHOP_ID=""  # id da barbearia dona deste número de WhatsApp

# IA (Copiloto + chatbot com IA). Sem esta chave tudo roda em modo simulado.
ANTHROPIC_API_KEY=""
# CHATBOT_MODEL="claude-opus-4-8"  # opcional (ex.: claude-haiku-4-5 p/ baratear)

# Relatório semanal automático (cron). Defina um segredo forte e use o mesmo
# no agendador que chama /api/cron/weekly-report?secret=...
CRON_SECRET=""

# Template APROVADO da Meta para a confirmação de agendamento. Sem isto, a
# confirmação sai como texto livre — que a Meta só entrega a quem mandou
# mensagem pra empresa nas últimas 24h (ou seja: NÃO chega a um cliente novo
# que acabou de agendar pelo app). Preencha com o nome do template aprovado.
# O template precisa ter 6 variáveis nesta ordem:
#   {{1}} cliente  {{2}} barbearia  {{3}} serviço  {{4}} barbeiro  {{5}} data  {{6}} hora
WHATSAPP_TEMPLATE_CONFIRMATION=""
# WHATSAPP_TEMPLATE_LANG="pt_BR"  # opcional

# Destinatário dos alertas da PLATAFORMA (cobrança falhou, barbearia suspensa,
# login de IP novo). Se vazio, usa o e-mail do primeiro SUPER_ADMIN.
PLATFORM_ALERT_EMAIL=""

# Web Push (notificação no celular com o app fechado, tipo WhatsApp). Gere o
# par com: node -e "console.log(require('web-push').generateVAPIDKeys())"
# A pública vai embutida no app; a privada NUNCA sai do servidor. Sem elas, o
# botão "Ativar notificações" fica oculto e /api/v1/push/public-key diz
# enabled:false. VAPID_SUBJECT é um mailto: ou https: de contato (exigido pelo
# protocolo — é como o serviço de push te avisa de problemas).
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contato@seudominio.com"

# WhatsApp multi-barbearia — Embedded Signup (conexão automática no painel).
# Só funcionam DEPOIS da sua plataforma ser aprovada pela Meta como Tech
# Provider (verificação da empresa + revisão do app). Até lá, o botão fica
# inerte e o gestor conecta pelo modo manual (número de teste).
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
# Mesmos valores expostos ao navegador (o SDK do Facebook roda no client):
NEXT_PUBLIC_FACEBOOK_APP_ID=""
# ID da configuração do WhatsApp Embedded Signup (criada no painel da Meta):
NEXT_PUBLIC_META_CONFIG_ID=""
