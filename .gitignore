# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# user-uploaded images (local disk storage, not source)
/public/uploads

# compiled Flutter web build, served temporarily for phone testing via the
# /mobile-app rewrite in next.config.ts — regenerate with:
# flutter build web --release --base-href /mobile-app/ --dart-define=API_BASE_URL=/api/v1
/public/mobile-app
