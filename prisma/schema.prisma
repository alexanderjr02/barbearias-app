generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          String   @default("OWNER")
  phone         String?
  avatar        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barbershop    Barbershop? @relation("BarbershopOwner")
  staffProfile  Staff?
  appointments  Appointment[] @relation("ClientAppointments")
  refreshTokens RefreshToken[]
  loyaltyAccounts LoyaltyAccount[]
  clientOf      BarbershopClient[]
  reviewsGiven  Review[]
}

model Barbershop {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  logo            String?
  coverImage      String?
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  primaryColor    String   @default("#D4AF37")
  secondaryColor  String   @default("#1a1a1a")
  instagram       String?
  whatsapp        String?
  isActive        Boolean  @default(true)
  plan            String   @default("FREE")
  pointsPerReal   Int      @default(10)
  ownerId         String   @unique
  owner           User     @relation("BarbershopOwner", fields: [ownerId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  staff           Staff[]
  services        Service[]
  appointments    Appointment[]
  products        Product[]
  transactions    FinancialTransaction[]
  chatMessages    ChatMessage[]
  workingHours    WorkingHour[]
  loyaltyAccounts LoyaltyAccount[]
  clients         BarbershopClient[]
}

model Staff {
  id            String   @id @default(cuid())
  name          String
  role          String   @default("BARBER")
  specialties   String?
  bio           String?
  avatar        String?
  commissionRate Float   @default(0.40)
  isActive      Boolean  @default(true)
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments  Appointment[]
  availability  Availability[]
  reviews       Review[]
}

model Service {
  id            String   @id @default(cuid())
  name          String
  description   String?
  image         String?
  duration      Int
  price         Float
  category      String   @default("HAIRCUT")
  isActive      Boolean  @default(true)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments  Appointment[]
}

model Appointment {
  id            String   @id @default(cuid())
  date          DateTime
  startTime     String
  endTime       String
  status        String   @default("SCHEDULED")
  notes         String?
  totalPrice    Float
  paymentStatus String   @default("PENDING")
  paymentMethod String?
  clientName    String
  clientPhone   String
  clientEmail   String?
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id])
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id])
  clientId      String?
  client        User?    @relation("ClientAppointments", fields: [clientId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  review        Review?
}

// One review per appointment, left by the client after it's COMPLETED.
// staffId is denormalized from the appointment so average-rating queries
// don't need to join through Appointment.
model Review {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  clientId      String
  client        User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  @@index([staffId])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  image         String?
  sku           String?
  price         Float
  costPrice     Float?
  quantity      Int      @default(0)
  minQuantity   Int      @default(5)
  category      String?
  brand         String?
  isActive      Boolean  @default(true)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FinancialTransaction {
  id            String   @id @default(cuid())
  type          String
  category      String
  description   String
  amount        Float
  date          DateTime @default(now())
  paymentMethod String?
  reference     String?
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model WorkingHour {
  id            String   @id @default(cuid())
  dayOfWeek     Int
  openTime      String
  closeTime     String
  isOpen        Boolean  @default(true)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([barbershopId, dayOfWeek])
}

model Availability {
  id            String   @id @default(cuid())
  dayOfWeek     Int
  startTime     String
  endTime       String
  isAvailable   Boolean  @default(true)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id            String   @id @default(cuid())
  content       String
  role          String
  sessionId     String
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model RefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// Marks a User as a client of a barbershop even before they have any
// Appointment — lets a gestor pre-register a client (see /api/clients POST).
// Clients who only ever booked as a guest have no row here; they're derived
// straight from Appointment instead (see the GET handler's merge logic).
model BarbershopClient {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([userId, barbershopId])
}

// tier is derived from `points` (see src/lib/loyalty.ts TIER_THRESHOLDS) —
// stored redundantly so it can be queried/sorted without recomputing.
model LoyaltyAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  points        Int      @default(0)
  tier          String   @default("BRONZE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  PointsTransaction[]

  @@unique([userId, barbershopId])
}

model PointsTransaction {
  id                String   @id @default(cuid())
  loyaltyAccountId  String
  loyaltyAccount    LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)
  amount            Int
  type              String   // EARNED | REDEEMED | ADJUSTED
  appointmentId     String?
  description       String?
  createdAt         DateTime @default(now())

  @@index([loyaltyAccountId])
}
