generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  // Nullable: a Google-only account (see src/app/api/auth/google/route.ts)
  // never sets a password — login/route.ts rejects password login for those
  // with a clear "use Google" error instead of a bcrypt.compare() crash.
  password      String?
  role          String   @default("OWNER")
  phone         String?
  avatar        String?
  dateOfBirth   DateTime?
  // Set once, on first Google sign-in — links this account to that Google
  // identity for all future logins (find-by-googleId before find-by-email).
  googleId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  barbershop    Barbershop? @relation("BarbershopOwner")
  staffProfile  Staff?
  appointments  Appointment[] @relation("ClientAppointments")
  refreshTokens RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  loyaltyAccounts LoyaltyAccount[]
  clientOf      BarbershopClient[]
  reviewsGiven  Review[]
  clientSubscriptions ClientSubscription[] @relation("ClientSubscriptions")

  // Platform-admin fields — unrelated to Staff.isActive (a barber's own
  // active/inactive flag on a shop's roster). This one gates login itself.
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  auditLogs     AuditLog[]
  loginEvents   LoginEvent[]

  // TOTP 2FA — opt-in, only meaningful for SUPER_ADMIN today. Secret is
  // stored in plaintext: no encryption/KMS infra exists anywhere in this
  // app (only bcrypt for passwords), so pretending to encrypt it would be
  // security theater rather than real protection.
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  ticketsCreated   SupportTicket[] @relation("TicketCreator")
  ticketMessages   TicketMessage[]

  announcementDismissals AnnouncementDismissal[]
  npsResponses     NpsResponse[]
  clientNotifications Notification[] @relation("ClientNotifications")
}

model Barbershop {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  logo            String?
  coverImage      String?
  phone           String?
  email           String?
  cnpj            String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  primaryColor    String   @default("#D4AF37")
  secondaryColor  String   @default("#1a1a1a")
  // App appearance customizer ("Aparência do app"): a curated, guard-railed
  // theming layer the gestor personalizes with their brand.
  themePreset     String?  // "midnight" | "graphite" | "neon" | "classic"
  themeMode       String?  // "dark" | "light"
  appTagline      String?  // subtitle shown on the app login
  bgType          String?  // login background: "gradient" | "image" | "video"
  bgVideo         String?  // background video URL (mp4)
  bgDim           Int?     // background overlay darkness 0-80
  bgBlur          Int?     // background blur in px 0-16
  bgGradient      Boolean  @default(true) // gradient scrim over the background
  bgEffect        String?  // animation: "none" | "zoom" | "pulse"
  // Owner-set monthly revenue goal, powering the finance "meta & ponto de
  // equilíbrio" cockpit. Null until the gestor sets one.
  monthlyGoal     Float?
  // Auto-piloto: automações que rodam sozinhas (cron), ligadas pelo gestor.
  autoConfirm     Boolean  @default(false) // confirma agendamentos de amanhã
  autoBirthday    Boolean  @default(false) // mensagem de aniversário
  autoWinbackDays Int?     // win-back de clientes sumidos há N dias (null = off)
  instagram       String?
  whatsapp        String?
  // PIX key that receives digital tips (gorjetas). Shown to the client to pay
  // the barber directly; null until the gestor sets one.
  pixKey          String?
  // Free-text FAQ / house rules the gestor writes ("aceita pix?", "tem
  // estacionamento?", "atende criança?"). Fed into the client chatbot's system
  // prompt so it answers shop-specific questions instead of guessing.
  faqText         String?
  isActive        Boolean  @default(true)
  plan            String   @default("FREE")
  // Mercado Pago recurring subscription (preapproval) that pays for `plan`.
  // Set when the gestor completes checkout; status mirrors MP
  // (authorized/paused/cancelled). Null on the free tier.
  mpPreapprovalId      String?
  mpSubscriptionStatus String?
  // How the barbershop receives its clients' membership payments. The gestor
  // picks a provider ("MERCADOPAGO" | "ASAAS" | ...) and connects their own
  // account; charges go straight to THEM (the platform never touches that
  // money). Null until connected → subscriptions run in simulated mode.
  paymentProvider      String?
  paymentApiKey        String?
  // Fiscal / NFS-e (nota fiscal de serviço). Provider-agnostic, same shape as
  // payments: the gestor connects a fiscal integrator (Focus NFe, NFe.io) at
  // deploy time. Null until connected → invoices run in simulated mode.
  fiscalProvider       String? // "FOCUSNFE" | "NFEIO"
  fiscalApiKey         String? // never returned by the API (stripped like paymentApiKey)
  municipalServiceCode String? // código do serviço municipal / item da lista
  taxRegime            String? // ex: "SIMPLES_NACIONAL"
  issRate              Float?  // alíquota do ISS (%)
  pointsPerReal   Int      @default(10)
  onboardingDismissed Boolean @default(false)
  ownerId         String   @unique
  owner           User     @relation("BarbershopOwner", fields: [ownerId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  staff           Staff[]
  services        Service[]
  appointments    Appointment[]
  products        Product[]
  transactions    FinancialTransaction[]
  chatMessages    ChatMessage[]
  workingHours    WorkingHour[]
  loyaltyAccounts LoyaltyAccount[]
  clients         BarbershopClient[]
  subscriptionPlans SubscriptionPlan[]
  waitlist        WaitlistEntry[]
  serviceInvoices ServiceInvoice[]
  tips            Tip[]
  copilotMemories CopilotMemory[]

  // Platform-admin fields (see AGENTS.md admin panel notes).
  platformInvoices  PlatformInvoice[]
  whiteLabelRequest WhiteLabelRequest?
  supportTickets    SupportTicket[]
  npsResponses      NpsResponse[]
  notifications     Notification[]
}

// Gestor-facing notification feed — shared per barbershop (not per user),
// since teams here are small enough that "someone on the team saw it" is
// good enough. Distinct from NotificationLog, which is the platform admin's
// own outbound-email audit trail.
model Notification {
  id           String   @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  // Set only for client-targeted notifications (their own appointment was
  // confirmed/cancelled/completed by the shop) — null means "shop-wide",
  // visible to gestor/staff via /api/notifications instead.
  clientId     String?
  client       User?    @relation("ClientNotifications", fields: [clientId], references: [id], onDelete: Cascade)
  type         String   // NEW_APPOINTMENT | APPOINTMENT_CANCELLED | SUPPORT_REPLY | APPOINTMENT_CONFIRMED | APPOINTMENT_CANCELLED_BY_SHOP | APPOINTMENT_COMPLETED
  title        String
  body         String
  link         String?
  read         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([barbershopId])
  @@index([clientId])
  @@index([read])
}

model Staff {
  id            String   @id @default(cuid())
  name          String
  role          String   @default("BARBER")
  specialties   String?
  bio           String?
  avatar        String?
  commissionRate Float   @default(0.40)
  isActive      Boolean  @default(true)
  userId        String?  @unique
  user          User?    @relation(fields: [userId], references: [id])
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments  Appointment[]
  availability  Availability[]
  timeOff       StaffTimeOff[]
  reviews       Review[]
  tips          Tip[]
}

model Service {
  id            String   @id @default(cuid())
  name          String
  description   String?
  image         String?
  duration      Int
  price         Float
  category      String   @default("HAIRCUT")
  isActive      Boolean  @default(true)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointments  Appointment[]
}

model Appointment {
  id            String   @id @default(cuid())
  date          DateTime
  startTime     String
  endTime       String
  status        String   @default("SCHEDULED")
  notes         String?
  totalPrice    Float
  paymentStatus String   @default("PENDING")
  paymentMethod String?
  clientName    String
  clientPhone   String
  clientEmail   String?
  referencePhoto String? // "quero esse de novo": cut photo the client wants
  // The "depois" of the antes/depois: a photo of the finished cut, taken by
  // the barber on checkout. Feeds the client's Carteira de Cortes and the
  // barber's auto-built portfolio.
  resultPhoto    String?
  // "Receita do corte" / ficha técnica — how this exact cut was executed, so
  // the next visit can be replicated identically. Barber-set on checkout;
  // the latest one for a client is pre-loaded next time.
  recipeMachine  String? // máquina & pente nas laterais (ex: "1.5 lados, 2 meio")
  recipeFinish   String? // acabamento / topo (tesoura, texturização)
  recipeProducts String? // produtos usados na finalização (pomada, etc.)
  recipeNotes    String? // observações livres da execução
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id])
  serviceId     String
  service       Service  @relation(fields: [serviceId], references: [id])
  clientId      String?
  client        User?    @relation("ClientAppointments", fields: [clientId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  review        Review?
  tip           Tip?
}

// A digital tip (gorjeta via PIX) a client leaves for the barber after a
// completed appointment. The shop's own PIX key receives the money directly —
// the platform only records the intent and lets the barber confirm receipt.
model Tip {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff       @relation(fields: [staffId], references: [id], onDelete: Cascade)
  barbershopId  String
  barbershop    Barbershop  @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  amount        Float
  status        String      @default("PENDING") // PENDING | CONFIRMED
  createdAt     DateTime    @default(now())

  @@index([staffId])
  @@index([barbershopId])
}

// One review per appointment, left by the client after it's COMPLETED.
// staffId is denormalized from the appointment so average-rating queries
// don't need to join through Appointment.
model Review {
  id            String   @id @default(cuid())
  appointmentId String   @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  clientId      String
  client        User     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String?
  createdAt     DateTime @default(now())

  @@index([staffId])
}

// Long-term memory of the Copiloto — durable facts and decisions about the
// business ("subiu o degradê pra R$50 em 10/07", "foca nas terças") that the
// AI records and reads back, so it acts like a consultant who remembers,
// independent of the raw chat transcript (stored in ChatMessage).
model CopilotMemory {
  id           String     @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  // When set, this is a note ABOUT a specific client (per-client memory the
  // barber saves — "alérgico a tal produto", "não gosta de conversa"). Null =
  // a general business fact/decision.
  clientId     String?
  content      String
  source       String     @default("chat") // chat | action
  createdAt    DateTime   @default(now())

  @@index([barbershopId])
  @@index([clientId])
}

model Product {
  id            String   @id @default(cuid())
  name          String
  description   String?
  image         String?
  sku           String?
  price         Float
  costPrice     Float?
  quantity      Int      @default(0)
  minQuantity   Int      @default(5)
  category      String?
  brand         String?
  isActive      Boolean  @default(true)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FinancialTransaction {
  id            String   @id @default(cuid())
  type          String
  category      String
  description   String
  amount        Float
  date          DateTime @default(now())
  paymentMethod String?
  reference     String?
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model WorkingHour {
  id            String   @id @default(cuid())
  dayOfWeek     Int
  openTime      String
  closeTime     String
  isOpen        Boolean  @default(true)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([barbershopId, dayOfWeek])
}

// A staff member's own weekly schedule, overriding the barbershop's default
// WorkingHour for that day of week. A missing row for a given dayOfWeek means
// "follow the barbershop's default hours" (see src/lib/scheduling.ts).
model Availability {
  id            String   @id @default(cuid())
  dayOfWeek     Int
  startTime     String
  endTime       String
  isAvailable   Boolean  @default(true)
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
}

// A one-off blocked day for a staff member (day off, vacation, sick day),
// regardless of what their weekly Availability/the shop's WorkingHour says.
model StaffTimeOff {
  id            String   @id @default(cuid())
  date          DateTime
  reason        String?
  staffId       String
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([staffId, date])
}

model ChatMessage {
  id            String   @id @default(cuid())
  content       String
  role          String
  sessionId     String
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
}

model RefreshToken {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// A nota fiscal de serviço (NFS-e) issued for an appointment/sale. Tracks the
// lifecycle at the fiscal provider so the gestor can download the PDF/XML.
model ServiceInvoice {
  id            String     @id @default(cuid())
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointmentId String?
  providerRef   String? // id/reference at the fiscal provider
  status        String     @default("PENDING") // PENDING | PROCESSING | AUTHORIZED | ERROR | CANCELLED
  number        String? // nota number once authorized
  pdfUrl        String?
  xmlUrl        String?
  amount        Float
  clientName    String
  clientDoc     String? // CPF/CNPJ do tomador
  message       String? // status/error detail from the provider
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([barbershopId])
}

// A client's grooming preferences ("seu barbeiro te conhece") — filled once by
// the client, shown to the barber on every appointment for a VIP-level, no-
// surprises service. A differentiator vs. other barbershop apps.
model ClientPreferences {
  id        String   @id @default(cuid())
  clientId  String   @unique
  machine   String? // ex: "máquina 2 nas laterais"
  products  String? // ex: "sem produto" / "pomada matte"
  allergies String?
  drink     String? // bebida favorita
  chat      String? // preferência de conversa
  notes     String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// A client's visual "cut passport" — photos of past haircuts so they can show
// the barber "quero esse de novo" instead of trying to explain. Client-first,
// a real differentiator vs. other barbershop apps.
model CutPhoto {
  id           String   @id @default(cuid())
  clientId     String
  barbershopId String?
  imageUrl     String
  note         String?
  createdAt    DateTime @default(now())

  @@index([clientId])
}

// Walk-in / no-slot clients waiting for an opening. The gestor works this
// simple queue from the dashboard — add, notify (WhatsApp), and clear.
model WaitlistEntry {
  id           String     @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  clientId     String? // set when the client joined it themselves (Auto-avise)
  clientName   String
  clientPhone  String
  note         String?
  status       String     @default("WAITING") // WAITING | DONE
  createdAt    DateTime   @default(now())

  @@index([barbershopId])
  @@index([clientId])
}

// Single-use, short-lived tokens for the "forgot password" flow. Only the
// SHA-256 hash of the token is stored (like RefreshToken), so a database leak
// never exposes a usable reset link. `usedAt` makes a token one-shot.
model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// Marks a User as a client of a barbershop even before they have any
// Appointment — lets a gestor pre-register a client (see /api/clients POST).
// Clients who only ever booked as a guest have no row here; they're derived
// straight from Appointment instead (see the GET handler's merge logic).
model BarbershopClient {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([userId, barbershopId])
}

// tier is derived from `points` (see src/lib/loyalty.ts TIER_THRESHOLDS) —
// stored redundantly so it can be queried/sorted without recomputing.
model LoyaltyAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  points        Int      @default(0)
  tier          String   @default("BRONZE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transactions  PointsTransaction[]

  @@unique([userId, barbershopId])
}

model PointsTransaction {
  id                String   @id @default(cuid())
  loyaltyAccountId  String
  loyaltyAccount    LoyaltyAccount @relation(fields: [loyaltyAccountId], references: [id], onDelete: Cascade)
  amount            Int
  type              String   // EARNED | REDEEMED | ADJUSTED
  appointmentId     String?
  description       String?
  createdAt         DateTime @default(now())

  @@index([loyaltyAccountId])
}

// Recurring membership plans a barbershop can offer its clients (auto
// monthly billing, like a gym or Netflix) — a White Label (ENTERPRISE)
// platform-plan exclusive, gated in src/context/PlanContext.tsx. Payment is
// simulated for now (see UpgradeModal.tsx for the same "no real gateway"
// pattern); client-facing subscribe flow is a future phase.
model SubscriptionPlan {
  id            String   @id @default(cuid())
  barbershopId  String
  barbershop    Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  price         Float
  billingCycle  String   @default("MONTHLY") // MONTHLY | QUARTERLY | ANNUAL
  benefits      String   // bullet points, one per line
  color         String   @default("#D4AF37")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions ClientSubscription[]
}

model ClientSubscription {
  id            String    @id @default(cuid())
  planId        String
  plan          SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  clientName    String
  clientPhone   String
  clientId      String?
  client        User?     @relation("ClientSubscriptions", fields: [clientId], references: [id])
  paymentMethod String    // PIX | CREDIT_CARD
  status        String    @default("ACTIVE") // PENDING | ACTIVE | PAST_DUE | CANCELLED
  // Mercado Pago references (when the barbershop charges through MP): the Pix
  // payment id and/or the recurring card preapproval id. Null in simulated mode.
  mpPaymentId     String?
  mpPreapprovalId String?
  startedAt     DateTime  @default(now())
  nextBillingAt DateTime
  cancelledAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([planId])
}

// Platform-level (SaaS) billing for a barbershop's own subscription to
// CORTIX itself — not to be confused with SubscriptionPlan/ClientSubscription
// above, which is a barbershop billing ITS OWN clients. No real payment
// gateway exists anywhere in this app (see UpgradeModal.tsx) — invoices here
// are a genuine DB ledger, generated by src/lib/billing.ts, not fabricated
// per-render. PLAN_CHANGE invoices are created already PAID (mirrors the
// instant-success simulation gestors already see today); RENEWAL invoices
// settle against the barbershop's real isActive flag at generation time.
model PlatformInvoice {
  id           String    @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  plan         String
  previousPlan String?   // set only on PLAN_CHANGE — powers MRR movement (expansion/contraction) reporting
  amount       Float
  status       String    @default("PENDING") // PENDING | PAID | FAILED | REFUNDED
  reason       String    // PLAN_CHANGE | RENEWAL
  periodStart  DateTime
  periodEnd    DateTime
  paidAt       DateTime?
  createdAt    DateTime  @default(now())

  refund       Refund?

  @@index([barbershopId])
  @@index([status])
}

// Every mutating action taken from the SUPER_ADMIN panel, for accountability
// and compliance — written by src/lib/audit.ts.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String   // e.g. "barbershop.plan_changed", "user.deactivated"
  targetType String   // "Barbershop" | "User" | "WhiteLabelRequest" | "PlatformInvoice" | "PlatformSetting"
  targetId   String
  metadata   String?  // JSON-encoded extra context
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

// Simple key/value store for platform-wide config editable from
// /admin/settings — starts with plan pricing/limits (see src/lib/billing.ts
// getPlanPricing()), which used to be hardcoded in PlanContext.tsx.
model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   // JSON-encoded
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// Honest tracker for ENTERPRISE ("White Label") branding requests — there is
// no real app-build/app-store pipeline in this codebase, so this is a manual
// queue the platform admin advances by hand, not an automated status feed.
model WhiteLabelRequest {
  id           String     @id @default(cuid())
  barbershopId String     @unique
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  status       String     @default("REQUESTED") // REQUESTED | IN_PROGRESS | DELIVERED
  notes        String?
  requestedAt  DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

// One row per successful login — lastLoginAt alone can't answer "how many
// distinct users were active this week," this can (real DAU/WAU/MAU, no
// fabricated history).
model LoginEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  isNewIp   Boolean  @default(false) // true if this IP was never seen before for this user
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// A ticket belongs to a barbershop (not a lone user) so every teammate at
// that shop sees the same thread — mirrors how BarbershopClient/Staff are
// already shop-scoped rather than user-scoped.
model SupportTicket {
  id           String   @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  createdById  String
  createdBy    User     @relation("TicketCreator", fields: [createdById], references: [id])
  subject      String
  status       String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  priority     String   @default("NORMAL") // LOW | NORMAL | HIGH
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  messages     TicketMessage[]

  @@index([barbershopId])
  @@index([status])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// A record of every event that "would" have gone out over email — no real
// provider is wired up anywhere in this app, so this is the honest stand-in:
// the exact rule/content/audience logic is real, only delivery is stubbed
// (see src/lib/notifications.ts for the single TODO integration point).
model NotificationLog {
  id        String   @id @default(cuid())
  type      String   // INVOICE_FAILED | BARBERSHOP_SUSPENDED | NEW_IP_LOGIN | HEALTH_SCORE_DROPPED
  status    String   @default("PENDING_INTEGRATION")
  subject   String
  body      String
  metadata  String?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model NotificationSetting {
  id      String  @id @default(cuid())
  type    String  @unique
  enabled Boolean @default(true)
}

// A platform-wide message the owner writes once and gestores see in their
// own dashboard (the bell icon in Topbar.tsx, previously decorative).
model PlatformAnnouncement {
  id         String   @id @default(cuid())
  title      String
  body       String
  isActive   Boolean  @default(true)
  audience   String   @default("ALL") // ALL | FREE | PRO | ENTERPRISE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  dismissals AnnouncementDismissal[]

  @@index([isActive])
}

model AnnouncementDismissal {
  id             String   @id @default(cuid())
  announcementId String
  announcement   PlatformAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  dismissedAt    DateTime @default(now())

  @@unique([announcementId, userId])
}

// A simple 0-10 satisfaction score, occasionally prompted to a gestor from
// their own dashboard — no external survey tool involved.
model NpsResponse {
  id           String   @id @default(cuid())
  barbershopId String
  barbershop   Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score        Int
  comment      String?
  createdAt    DateTime @default(now())

  @@index([barbershopId])
}

// A formal refund against an already-PAID PlatformInvoice — separate from
// just marking an invoice FAILED, since a refund is a deliberate reversal
// with a reason, not a payment that never landed.
model Refund {
  id          String   @id @default(cuid())
  invoiceId   String   @unique
  invoice     PlatformInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount      Float
  reason      String
  processedBy String
  createdAt   DateTime @default(now())
}
